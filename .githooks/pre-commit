#!/bin/sh
# Pre-commit hook — bloqueia dados pessoais antes de qualquer commit.
# Instalação: sh setup.sh  (uma vez após clonar)

PATTERNS='escutedentro\|/Users/[a-z]\|Outputs Claude\|_edm_\|64\.115\.123\|@gmail\.com'

FOUND=""
for file in $(git diff --cached --name-only); do
  case "$file" in
    *.md|*.json|*.js|*.ts|*.html|*.txt|*.sh)
      hits=$(grep -n "$PATTERNS" "$file" 2>/dev/null)
      if [ -n "$hits" ]; then
        FOUND="$FOUND\n  $file:\n$hits"
      fi
      ;;
  esac
done

if [ -n "$FOUND" ]; then
  printf "\n🚫 COMMIT BLOQUEADO — dados pessoais detectados:\n"
  printf "$FOUND\n"
  printf "\nSubstituir pelos placeholders antes de commitar.\n"
  printf "Padrões bloqueados: escutedentro, /Users/, _edm_, @gmail.com, CNPJs, Outputs Claude\n\n"
  exit 1
fi

exit 0
